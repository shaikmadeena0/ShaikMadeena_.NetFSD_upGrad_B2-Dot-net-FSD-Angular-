SELECT product_name, model_year, list_price
FROM Products p1
WHERE list_price >
(
    SELECT AVG(list_price)
    FROM Products p2
    WHERE p2.category_id = p1.category_id
);


SELECT 
    product_name,
    category_id,
    list_price,
    (list_price - 
        (SELECT AVG(list_price) 
         FROM Products p2 
         WHERE p2.category_id = p1.category_id)
    ) AS price_difference
FROM Products p1;





SELECT 
product_name + ' (' + CAST(model_year AS VARCHAR) + ')' AS Product_Details
FROM Products;
