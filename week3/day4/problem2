---Calculate Total Order Value
SELECT customer_id, SUM(total_amount) AS total_value
FROM Orders
GROUP BY customer_id




----Join Customers with Total Orders


FROM Customers c
JOIN
(
    SELECT customer_id, SUM(total_amount) AS total_value
    FROM Orders
    GROUP BY customer_id
) 
t ON c.customer_id = t.customer_id

----Display Full Name

c.first_name + ' ' + c.last_name AS Full_Name

----Classify Customers Using CASE

CASE
    WHEN t.total_value > 10000 THEN 'Premium'
    WHEN t.total_value BETWEEN 5000 AND 10000 THEN 'Regular'
    ELSE 'Basic'



